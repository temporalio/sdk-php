# Basic/Timer parity scenario.
# Workflow sleeps for a fixed duration. Exercises TimerStarted/TimerFired
# events + the DurationNormalizer rule.

SCENARIO_NAME="Basic/Timer"

SDKS="java php go"
JAVA_DIR="java"
FIXTURE_JAVA="fixtures/java.json"

PHP_FIXTURE_RUNNER="php/scenario.php"

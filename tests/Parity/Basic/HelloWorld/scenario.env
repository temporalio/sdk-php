# Basic/HelloWorld parity scenario.
# A single-method workflow with no activities and no Nexus calls — the
# minimal Temporal history a real workflow can produce.

SCENARIO_NAME="Basic/HelloWorld"

SDKS="java php go"
JAVA_DIR="java"
FIXTURE_JAVA="fixtures/java.json"

PHP_FIXTURE_RUNNER="php/scenario.php"
PHP_WORKFLOW_TYPE="Parity_Basic_HelloWorld"
FIXTURE_PHP="fixtures/php.json"

GO_DIR="go"
GO_BIN="build/go-bin/helloworld"
FIXTURE_GO="fixtures/go.json"
